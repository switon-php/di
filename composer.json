{
  "name": "switon/di",
  "description": "Dependency injection container and autowiring for Switon Framework",
  "type": "library",
  "keywords": [
    "switon",
    "dependency-injection",
    "container",
    "autowiring"
  ],
  "homepage": "https://github.com/switon-php/di",
  "license": "MIT",
  "authors": [
    {
      "name": "switon",
      "email": "admin@switon.dev"
    }
  ],
  "support": {
    "source": "https://github.com/switon-php/di",
    "issues": "https://github.com/switon-php/di/issues",
    "docs": "https://docs.switon.dev/latest/di"
  },
  "require": {
    "php": ">=8.3",
    "ext-json": "*",
    "psr/container": "^2.0",
    "psr/event-dispatcher": "^1.0",
    "switon/core": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0"
  },
  "autoload": {
    "psr-4": {
      "Switon\\Di\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Switon\\Di\\Tests\\": "tests/"
    }
  },
  "extra": {
    "switon": {
      "providers": [
        "Switon\\Di\\ServiceProvider"
      ],
      "commands": [
        "Switon\\Di\\Command\\ContainerCommand"
      ]
    }
  }
}
